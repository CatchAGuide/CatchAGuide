APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# DigitalOcean Spaces (S3-compatible object storage)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=catchaguide-assets
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_URL=https://catchaguide-assets.fra1.cdn.digitaloceanspaces.com
DO_SPACES_USE_PATH_STYLE_ENDPOINT=false

# Media storage (set MEDIA_STORAGE_DISK=public for local-only dev without DO)
MEDIA_STORAGE_DISK=do_spaces
MEDIA_STORAGE_LOCAL_DISK=public
# Build CDN URLs without S3 HEAD calls (recommended for PageSpeed)
MEDIA_URL_SKIP_EXISTS=true
# Cache backend exists checks for read/move/delete (seconds; 0 = disabled)
MEDIA_EXISTS_CACHE_TTL=86400
# public = browser-accessible URLs on DO Spaces (public-read ACL)
MEDIA_OBJECT_VISIBILITY=public

# Bulk sync local folders to DO (run on production server — see media:sync-directories)
# php artisan media:sync-directories --from-listing-media --prefix=production --skip-existing

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

STRIPE_KEY="pk_test_51KMW0XE57Dznhj0USX7mZPIqd92GqnrKuK9NFHMAEM1g2QWkNn65VtAf0RCjIfmRlb0gE4GSLEvKM3r2asfO1ZQR00IANmJ62j"
STRIPE_SECRET="sk_test_51KMW0XE57Dznhj0Ua2UYDsu09MQzfuDQnJHEXmv1MqJrhKPfy0r28u3EW1D4le3Q5VN2dfWJrEbp4MxT4SXvk6Nk00s3IamINT"
CASHIER_CURRENCY=eur

TO_MAIL=info@catchaguide.com
CC_MAIL=info@catchaguide.com
# New guide applications are emailed to TO_CEO (override with GUIDE_ADMIN_NOTIFICATION_EMAIL if needed)
TO_CEO=info@catchaguide.com

PRICE_CAT_0=0
PRICE_CAT_1=350
PRICE_CAT_2=1500

PRICE_CAT_0_FEE=0.10
PRICE_CAT_1_FEE=0.075
PRICE_CAT_2_FEE=0.003

# Public booking assistant (Groq — separate from Gemini translation)
BOOKING_ASSISTANT_ENABLED=false
BOOKING_ASSISTANT_WIDGET_VISIBLE=false
BOOKING_ASSISTANT_PREVIEW_TOKEN=
BOOKING_ASSISTANT_PREVIEW_PATH=hub/cag-ba-preview
BOOKING_ASSISTANT_DRIVER=groq
BOOKING_ASSISTANT_GROQ_API_KEY=
BOOKING_ASSISTANT_GROQ_MODEL=llama-3.1-8b-instant
BOOKING_ASSISTANT_MAX_OUTPUT_TOKENS=512
BOOKING_ASSISTANT_MAX_MESSAGES=16
BOOKING_ASSISTANT_MAX_TOOL_ITERATIONS=3
BOOKING_ASSISTANT_RATE_PER_MINUTE=15

# Site contact (shown in header/footer JSON-LD and phone links)
CONTACT_NUM=

# Google Maps (required for maps, geocoding, Places autocomplete)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=

# Google Gemini (translation / AI features)
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-pro

# Locale-specific public URLs (hreflang, canonicals)
EN_APP_URL=https://www.catchaguide.com
DE_APP_URL=https://www.catchaguide.de